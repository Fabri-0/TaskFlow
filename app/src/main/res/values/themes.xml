<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TaskFlow" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorPrimaryVariant">@color/primary_purple_dark</item>
        <item name="colorSecondary">@color/accent_pink</item>
        <item name="android:fontFamily">sans</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/bg_dark_2</item>
        <item name="android:navigationBarColor">@color/bg_dark_2</item>
        <item name="android:windowActionModeOverlay">true</item>
    </style>

    <style name="Widget.TaskFlow.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/card_dark</item>
        <item name="boxStrokeColor">@color/primary_purple</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>

    <style name="Widget.TaskFlow.FilterChip" parent="Widget.MaterialComponents.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipMinHeight">40dp</item>
        <item name="ensureMinTouchTargetSize">false</item>
    </style>

    <style name="Widget.TaskFlow.Weekday" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.TaskFlow.StatBox" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">@drawable/bg_card_soft</item>
        <item name="android:padding">14dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.TaskFlow.DrawerRow" parent="@android:style/Widget.TextView">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">14dp</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:layout_marginEnd">14dp</item>
        <item name="android:background">@drawable/bg_drawer_section</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TaskFlowCenterDialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_center_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_center_out</item>
    </style>

    <style name="ThemeOverlay_TaskFlow_PickerWidget">
        <item name="android:colorAccent">@color/primary_purple</item>
        <item name="colorAccent">@color/primary_purple</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/card_dark_soft</item>
    </style>
</resources>
