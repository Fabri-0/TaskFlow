<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="168dp"
    android:layout_margin="14dp"
    android:background="@drawable/bg_drawer_header"
    android:gravity="bottom"
    android:orientation="vertical"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/bg_profile_glass"
            android:gravity="center"
            android:text="🐇"
            android:textSize="24sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="TaskFlow"
            android:textColor="@color/on_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/buttonPermissionSettings"
            android:layout_width="42dp"
            android:layout_height="42dp"
            android:background="@drawable/bg_profile_glass"
            android:contentDescription="Permisos"
            android:padding="10dp"
            android:src="@drawable/ic_settings_24"
            app:tint="@color/on_primary" />
    </LinearLayout>

    <TextView
        android:id="@+id/textDrawerSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:text="Organiza tareas, clases y metas ✨"
        android:textColor="@color/on_primary"
        android:textSize="14sp" />
</LinearLayout>
