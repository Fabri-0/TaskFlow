<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient_dark"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    android:paddingStart="18dp"
    android:paddingTop="38dp"
    android:paddingEnd="18dp"
    android:paddingBottom="18dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_home_panel"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:id="@+id/textCalendarTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calendario 📅"
            android:textColor="@color/on_primary"
            android:textSize="29sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="Tus dias con tareas se iluminan para que no se escape nada."
            android:textColor="@color/on_primary"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/textMonthTaskCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:background="@drawable/bg_profile_glass"
                android:paddingStart="13dp"
                android:paddingTop="8dp"
                android:paddingEnd="13dp"
                android:paddingBottom="8dp"
                android:textColor="@color/on_primary"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_profile_glass"
                android:paddingStart="11dp"
                android:paddingTop="8dp"
                android:paddingEnd="11dp"
                android:paddingBottom="8dp"
                android:textColor="@color/on_primary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
        android:background="@drawable/bg_card_dark"
        android:orientation="vertical"
            android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonPreviousMonth"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="‹"
                android:textAllCaps="false"
                android:textColor="@color/on_primary"
                android:textSize="24sp"
                app:backgroundTint="@color/accent_blue" />

            <TextView
                android:id="@+id/textMonthName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonNextMonth"
                android:layout_width="46dp"
                android:layout_height="46dp"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:text="›"
                android:textAllCaps="false"
                android:textColor="@color/on_primary"
                android:textSize="24sp"
                app:backgroundTint="@color/accent_teal" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">

            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="lun" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="mar" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="mie" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="jue" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="vie" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="sab" />
            <TextView style="@style/Widget.TaskFlow.Weekday" android:text="dom" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerCalendarDays"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="8dp"
            android:overScrollMode="never"
            android:scrollbars="none" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCalendarTasks"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />
</LinearLayout>
