<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_panel"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dialog_danger_header"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/textDeleteTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/on_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDeleteMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:textColor="@color/on_primary"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:background="@drawable/bg_card_soft"
        android:padding="14dp"
        android:text="Esta accion no elimina tus tareas, solo limpia esta opcion de organizacion."
        android:textColor="@color/text_primary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeleteCancel"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Cancelar"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            app:backgroundTint="@color/card_dark_soft" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonDeleteConfirm"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Eliminar"
            android:textAllCaps="false"
            android:textColor="@color/on_primary"
            app:backgroundTint="@color/danger"
            app:icon="@drawable/ic_delete_24"
            app:iconTint="@color/on_primary" />
    </LinearLayout>
</LinearLayout>
